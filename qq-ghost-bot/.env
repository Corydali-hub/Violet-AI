# OneBot 连接 — NapCat WebSocket 端口 6700
ONEBOT_WS_URL=ws://127.0.0.1:6700

# LLM API 配置
LLM_API_KEY=
LLM_API_BASE=
LLM_MODEL=

# 机器人名字/主人qq号/主人称呼
BOT_NAME=
OWNER_ID=
OWNER_TITLE=

# 群组白名单（逗号分隔，留空则允许所有群）
GROUP_WHITELIST=

# 行为概率
PROB_MIMIC=0.25
PROB_REPLAY=0.1

# 冷却 & 容量
COOLDOWN_SECONDS=8
MAX_HISTORY_PER_GROUP=500
